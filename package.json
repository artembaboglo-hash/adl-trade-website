{
  "name": "adl-trade-website",
  "version": "1.0.0",
  "private": true,
  "engines": {
    "node": ">=20.9.0 <26"
  },
  "scripts": {
    "clean": "rm -rf .next",
    "clean:cache": "rm -rf .next/cache node_modules/.cache",
    "clean:all": "rm -rf .next node_modules/.cache",
    "dev": "node scripts/dev-server.cjs",
    "dev:3000": "WATCHPACK_POLLING=true next dev --hostname 0.0.0.0 --port 3000",
    "dev:loopback": "WATCHPACK_POLLING=true next dev --hostname 127.0.0.1 --port 3000",
    "dev:3001": "WATCHPACK_POLLING=true next dev --hostname 0.0.0.0 --port 3001",
    "dev:alt": "WATCHPACK_POLLING=true next dev --hostname 0.0.0.0 --port 3002",
    "dev:lan": "WATCHPACK_POLLING=true next dev --hostname 0.0.0.0 --port 3000",
    "dev:docker": "WATCHPACK_POLLING=true next dev --hostname 0.0.0.0 --port 3000",
    "dev:turbo": "next dev --turbo --hostname 0.0.0.0 --port 3000",
    "dev:webpack": "npm run dev",
    "dev:clean": "npm run clean && npm run dev",
    "dev:fresh": "npm run clean:all && npm run dev",
    "fix:cache": "npm run clean:all && npm run build",
    "fix:500": "npm run fix:cache && npm run dev",
    "fix:500:prod": "npm run clean && npm run build && npm run start",
    "fix:chunks": "npm run clean:all && npm run dev",
    "fix": "npm run clean:all && npm install && npm run build",
    "start:fresh": "npm run clean:all && npm run build && next start",
    "prebuild": "node scripts/prebuild-clean.cjs",
    "build": "next build",
    "build:clean": "npm run clean && npm run build",
    "prestart": "node scripts/check-next-server.cjs",
    "start": "next start",
    "lint": "next lint",
    "verify": "npm run lint && npm run build",
    "favicon": "node scripts/generate-favicon.cjs",
    "doctor": "node scripts/doctor.cjs",
    "reinstall": "rm -rf node_modules && npm install"
  },
  "dependencies": {
    "clsx": "^2.1.1",
    "next": "^15.3.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "sharp": "^0.34.5"
  },
  "devDependencies": {
    "@types/node": "^22.15.3",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "autoprefixer": "^10.4.21",
    "eslint": "^9.25.0",
    "eslint-config-next": "^15.3.0",
    "postcss": "^8.5.3",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.8.3"
  }
}
