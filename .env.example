# --- Form mail (/api/inquiry) ---
#
# Railway Hobby (and similar) often blocks outbound SMTP (465/587), which shows as
# ETIMEDOUT on CONN. Use Resend (HTTPS) below, or upgrade Railway for SMTP egress.
#
# Option A — Resend (recommended on Railway Hobby): set API key; optional MAIL_* below.
# Verify your domain in Resend; MAIL_FROM must use that domain.
# https://resend.com/docs/dashboard/domains/introduction
RESEND_API_KEY=

# Option B — SMTP (Hostinger, etc.). Ignored if RESEND_API_KEY is set.
SMTP_HOST=smtp.hostinger.com
SMTP_PORT=465
# Set to "false" only if using STARTTLS on port 587 (not typical for 465).
SMTP_SECURE=true
SMTP_USER=
SMTP_PASS=

# From header (optional; defaults to SMTP_USER with SMTP, required style for Resend).
# Example: "ADL Trade <noreply@adltrade.com>"
MAIL_FROM=
# Inbox that receives form submissions (optional; defaults to SMTP_USER for SMTP-only)
MAIL_TO=

# Optional: comma-separated extra hostnames allowed for Origin (production), e.g. preview domains
# SMTP_ALLOWED_ORIGIN_HOSTS=

# Set to "true" to skip IPv4 resolution (default: resolve smtp.host to IPv4 for no-IPv6 egress)
# SMTP_USE_HOSTNAME=

# Optional nodemailer timeouts (ms), SMTP only
# SMTP_CONNECTION_TIMEOUT_MS=20000
# SMTP_GREETING_TIMEOUT_MS=20000
# SMTP_SOCKET_TIMEOUT_MS=20000

# Form file attachments (/api/inquiry, multipart). Per-file and total are binary bytes.
# INQUIRY_MAX_FILES=5
# INQUIRY_MAX_ATTACHMENT_BYTES=26214400
# INQUIRY_MAX_TOTAL_ATTACHMENT_BYTES=52428800
