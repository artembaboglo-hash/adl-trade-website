# SMTP (Hostinger or other). Required for /api/inquiry in production.
SMTP_HOST=smtp.hostinger.com
SMTP_PORT=465
# Set to "false" only if using STARTTLS on port 587 (not typical for 465).
SMTP_SECURE=true
SMTP_USER=
SMTP_PASS=

# From header (optional; defaults to SMTP_USER). Example: "ADL Trade <noreply@adltrade.com>"
MAIL_FROM=
# Inbox that receives form submissions (optional; defaults to SMTP_USER)
MAIL_TO=

# Optional: comma-separated extra hostnames allowed for Origin (production), e.g. preview domains
# SMTP_ALLOWED_ORIGIN_HOSTS=
